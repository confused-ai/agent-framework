{
  "name": "@confused-ai/sdk",
  "version": "0.1.0",
  "description": "High-level SDK: typed agent definitions, multi-step workflows, orchestration adapters",
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@confused-ai/contracts": "0.1.0",
    "@confused-ai/core": "0.1.0",
    "@confused-ai/execution": "0.1.0",
    "@confused-ai/memory": "0.1.0",
    "@confused-ai/orchestration": "0.1.0",
    "@confused-ai/planner": "0.1.0",
    "@confused-ai/session": "0.1.0",
    "@confused-ai/tools": "0.1.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "module": "./dist/index.js",
  "publishConfig": {
    "access": "public"
  }
}
