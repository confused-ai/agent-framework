{
  "name": "@confused-ai/skills",
  "version": "0.1.0",
  "description": "Reference skills for confused-ai agents: web research, PDF summarisation, code review.",
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@confused-ai/contracts": "0.1.0"
  },
  "peerDependencies": {
    "@confused-ai/tools": "0.1.0"
  },
  "peerDependenciesMeta": {
    "@confused-ai/tools": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "tsup": "^8.0.2",
    "vitest": "^1.6.0"
  },
  "module": "./dist/index.js",
  "publishConfig": {
    "access": "public"
  }
}
