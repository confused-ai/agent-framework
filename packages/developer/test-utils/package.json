{
  "name": "@confused-ai/test-utils",
  "version": "0.1.0",
  "description": "Testing utilities for confused-ai: mock agents, mock LLM providers, scenario builders.",
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./conformance": {
      "types": "./dist/conformance.d.ts",
      "import": "./dist/conformance.js",
      "require": "./dist/conformance.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@confused-ai/contracts": "0.1.0",
    "@confused-ai/core": "0.1.0"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "license": "MIT",
  "module": "./dist/index.js",
  "publishConfig": {
    "access": "public"
  }
}
