{
  "name": "@confused-ai/guardrails",
  "version": "0.1.0",
  "description": "Production guardrails: input/output validation, PII detection, prompt injection protection, content moderation, allowlists",
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^4.4.3",
    "@confused-ai/core": "0.1.0"
  },
  "devDependencies": {
    "tsup": "*",
    "typescript": "*"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "module": "./dist/index.js",
  "publishConfig": {
    "access": "public"
  }
}
