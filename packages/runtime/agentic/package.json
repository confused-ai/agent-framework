{
  "name": "@confused-ai/agentic",
  "version": "0.1.0",
  "description": "ReAct-style agentic loop with tool dispatch, guardrails, and human-in-the-loop",
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@confused-ai/contracts": "0.1.0",
    "@confused-ai/core": "0.1.0",
    "@confused-ai/guard": "0.1.0",
    "@confused-ai/guardrails": "0.1.0",
    "@confused-ai/observe": "0.1.0",
    "@confused-ai/shared": "0.1.0",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@confused-ai/compression": "0.1.0",
    "@confused-ai/knowledge": "0.1.0",
    "@confused-ai/production": "0.1.0",
    "@confused-ai/reasoning": "0.1.0",
    "@opentelemetry/api": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "@confused-ai/compression": {
      "optional": true
    },
    "@confused-ai/knowledge": {
      "optional": true
    },
    "@confused-ai/production": {
      "optional": true
    },
    "@confused-ai/reasoning": {
      "optional": true
    },
    "@opentelemetry/api": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsup": "*",
    "typescript": "*"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "module": "./dist/index.js",
  "publishConfig": {
    "access": "public"
  }
}
