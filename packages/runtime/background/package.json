{
  "name": "@confused-ai/background",
  "version": "0.1.0",
  "description": "Background queue adapters for AI agent hooks: BullMQ, Kafka, RabbitMQ, Redis, SQS, in-memory",
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@confused-ai/contracts": "0.1.0"
  },
  "peerDependencies": {
    "bullmq": ">=4.0.0",
    "kafkajs": ">=2.0.0",
    "amqplib": ">=0.10.0",
    "ioredis": ">=5.0.0",
    "@aws-sdk/client-sqs": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "bullmq": {
      "optional": true
    },
    "kafkajs": {
      "optional": true
    },
    "amqplib": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    },
    "@aws-sdk/client-sqs": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsup": "*",
    "typescript": "*"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "module": "./dist/index.js",
  "publishConfig": {
    "access": "public"
  }
}
