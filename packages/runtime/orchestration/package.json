{
  "name": "@confused-ai/orchestration",
  "version": "0.1.0",
  "description": "Multi-agent orchestration: team, swarm, supervisor, pipeline, consensus, handoff, A2A, MCP toolkit",
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@confused-ai/agentic": "0.1.0",
    "@confused-ai/contracts": "0.1.0",
    "@confused-ai/core": "0.1.0",
    "@confused-ai/memory": "0.1.0",
    "@confused-ai/models": "0.1.0",
    "@confused-ai/observe": "0.1.0",
    "@confused-ai/planner": "0.1.0",
    "@confused-ai/shared": "0.1.0",
    "@confused-ai/tools": "0.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "tsup": "*",
    "typescript": "*"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "module": "./dist/index.js",
  "publishConfig": {
    "access": "public"
  }
}
