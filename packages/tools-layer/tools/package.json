{
  "name": "@confused-ai/tools",
  "version": "0.1.0",
  "description": "Built-in tool set for confused-ai. Built-in Node.js tools are eager; heavy-dep tools (browser, DB) are lazy.",
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./http": {
      "types": "./dist/http-client.d.ts",
      "import": "./dist/http-client.js",
      "require": "./dist/http-client.cjs"
    },
    "./fs": {
      "types": "./dist/file-system.d.ts",
      "import": "./dist/file-system.js",
      "require": "./dist/file-system.cjs"
    },
    "./shell": {
      "types": "./dist/shell.d.ts",
      "import": "./dist/shell.js",
      "require": "./dist/shell.cjs"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js",
      "require": "./dist/browser.cjs"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "require": "./dist/core/index.cjs"
    },
    "./mcp": {
      "types": "./dist/mcp/index.d.ts",
      "import": "./dist/mcp/index.js",
      "require": "./dist/mcp/index.cjs"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js",
      "require": "./dist/utils/index.cjs"
    },
    "./communication": {
      "types": "./dist/communication/index.d.ts",
      "import": "./dist/communication/index.js",
      "require": "./dist/communication/index.cjs"
    },
    "./productivity": {
      "types": "./dist/productivity/index.d.ts",
      "import": "./dist/productivity/index.js",
      "require": "./dist/productivity/index.cjs"
    },
    "./devtools": {
      "types": "./dist/devtools/index.d.ts",
      "import": "./dist/devtools/index.js",
      "require": "./dist/devtools/index.cjs"
    },
    "./crm": {
      "types": "./dist/crm/index.d.ts",
      "import": "./dist/crm/index.js",
      "require": "./dist/crm/index.cjs"
    },
    "./search": {
      "types": "./dist/search/index.d.ts",
      "import": "./dist/search/index.js",
      "require": "./dist/search/index.cjs"
    },
    "./scraping": {
      "types": "./dist/scraping/index.d.ts",
      "import": "./dist/scraping/index.js",
      "require": "./dist/scraping/index.cjs"
    },
    "./media": {
      "types": "./dist/media/index.d.ts",
      "import": "./dist/media/index.js",
      "require": "./dist/media/index.cjs"
    },
    "./memory": {
      "types": "./dist/memory/index.d.ts",
      "import": "./dist/memory/index.js",
      "require": "./dist/memory/index.cjs"
    },
    "./ai": {
      "types": "./dist/ai/index.d.ts",
      "import": "./dist/ai/index.js",
      "require": "./dist/ai/index.cjs"
    },
    "./data": {
      "types": "./dist/data/index.d.ts",
      "import": "./dist/data/index.js",
      "require": "./dist/data/index.cjs"
    },
    "./finance": {
      "types": "./dist/finance/index.d.ts",
      "import": "./dist/finance/index.js",
      "require": "./dist/finance/index.cjs"
    },
    "./social": {
      "types": "./dist/social/index.d.ts",
      "import": "./dist/social/index.js",
      "require": "./dist/social/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src --max-warnings 0"
  },
  "dependencies": {
    "@confused-ai/contracts": "0.1.0",
    "@confused-ai/core": "0.1.0",
    "@confused-ai/shared": "0.1.0",
    "zod": "^3.0.0"
  },
  "peerDependencies": {
    "playwright": ">=1.0.0",
    "duck-duck-scrape": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    },
    "duck-duck-scrape": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "license": "MIT",
  "module": "./dist/index.js",
  "publishConfig": {
    "access": "public"
  }
}
